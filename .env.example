ENV=dev                                                         # 运行环境，可选值：dev | stg | prd

# 当前使用的 LLM 提供商。决定凭据、元数据和默认模型从何处读取。
# 留空则默认使用 nv_build。
# 可选值：openai | anthropic | nv_build
SKILLSPECTOR_PROVIDER=

# 提供商凭据 — 根据 SKILLSPECTOR_PROVIDER 设置对应项
# （或留空 SKILLSPECTOR_PROVIDER 并设置 NVIDIA_INFERENCE_KEY 使用默认 nv_build）

# nv_build 提供商（默认）
NVIDIA_INFERENCE_KEY=

# openai 提供商；OPENAI_BASE_URL 可指向任意 OpenAI 兼容端点
# （Ollama、vLLM、其他推理网关等）；留空则使用 api.openai.com
OPENAI_API_KEY=
OPENAI_BASE_URL=

# anthropic 提供商
ANTHROPIC_API_KEY=

# SkillSpector 配置
SKILLSPECTOR_MODEL=                                             # 留空使用当前提供商内置默认模型（见 README）；可覆盖（如 gpt-5.2）
# SKILLSPECTOR_MODEL_REGISTRY=./model_registry.yaml             # 可选：覆盖模型注册表；默认使用 src/skillspector/providers/ 下各提供商内置 YAML
SKILLSPECTOR_LOG_LEVEL=WARNING                                  # 日志级别，可选：DEBUG | INFO | WARNING | ERROR

# langchain/langsmith 配置（均为可选）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_WORKSPACE=
LANGCHAIN_PROJECT=
LANGCHAIN_ENDPOINT=
